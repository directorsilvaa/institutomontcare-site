{
  "name": "institutomontcare",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run prepare:build-html && npm run build:vite && npm run prepare:public-html && npm run prepare:dev-html",
    "build:vite": "node --max-old-space-size=1024 ./node_modules/vite/bin/vite.js build",
    "prepare:build-html": "node scripts/prepare-build-html.js",
    "prepare:public-html": "node scripts/prepare-public-html.js",
    "prepare:dev-html": "node scripts/sync-dev-html.js",
    "start": "node server.js",
    "preview": "node server.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^4.5.14"
  }
}
